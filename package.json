{
  "name": "latex-editor-backend",
  "version": "1.0.0",
  "description": "Overleaf-like LaTeX editor backend — Hono + Render Native Runtime",
  "private": true,
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "dev": "tsx watch src/index.ts",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "prisma db seed",
    "start": "node dist/index.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@hono/node-ws": "^1.0.4",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.43.4",
    "bcryptjs": "^2.4.3",
    "hono": "^4.4.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "y-websocket": "^1.5.4",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "prisma": "^5.14.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
